# Copy to .env and adjust. Vite exposes only variables prefixed with VITE_.
# Backend uses paths like /threat-indicators (no /api prefix). Same machine:
VITE_API_BASE_URL=http://localhost:8080
# From another device (phone, tablet), use your PC LAN IP instead of localhost, e.g.:
# VITE_API_BASE_URL=http://192.168.1.42:8080
# Then run: npm run dev -- --host — open Network URL from the terminal on the phone browser.
