# Copy to `.env` for overrides. Vite only exposes vars prefixed with VITE_.
#
# Development (`npm run dev`): use committed `.env.development` with empty URL so the SPA and
# `/threat-indicators`, `/ai` share one origin (`http://PC_IP:5173`) — fixes mobile LAN access.
#
# Production build: point at your real API host (same or different origin — CORS is enabled on JVM).
VITE_API_BASE_URL=https://api.example.com
#
# JVM location for Node proxy only (dev/preview); default ok if backend is on this PC :
# VITE_BACKEND_PROXY_TARGET=http://127.0.0.1:8080
